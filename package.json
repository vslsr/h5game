{
  "name": "h5sgame",
  "version": "1.0.0",
  "description": "H5 Small Game Server (TypeScript + Vite)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c auto \"tsx watch server/server.ts\" \"vite\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite",
    "start": "tsx server/server.ts",
    "build": "tsc -b && vite build",
    "build:ci": "npm ci && npm run build",
    "start:prod": "node server/server.js",
    "nginxReload": "cd c:\\wkspc\\h5sgame\\nginx-1.30.2 && .\\nginx.exe -t && .\\nginx.exe -s reload",
    "kill-port": "powershell -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess | Sort-Object -Unique | ForEach-Object { Stop-Process -Id $_ -Force }; Write-Host 'Killed processes on port 3000'\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "socket.io-client": "^4.7.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^4.5.14"
  }
}
